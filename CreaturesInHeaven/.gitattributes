# Enforce LF line endings for all text files
* text=auto eol=lf

# Unity-specific
*.cs text eol=lf
*.unity text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.asset text eol=lf merge=unityyamlmerge
*.meta text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.shader text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.tiff binary
*.psd binary
*.fbx binary
*.mp3 binary
*.wav binary
*.ogg binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.unitypackage binary
