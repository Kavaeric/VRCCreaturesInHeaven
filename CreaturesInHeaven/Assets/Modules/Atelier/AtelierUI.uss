/* --- Typography --- */

.text-xs   { font-size: 10px; }
.text-sm   { font-size: 12px; }
.text-base { font-size: 14px; }
.text-lg   { font-size: 16px; }
.text-xl   { font-size: 18px; }
.text-2xl  { font-size: 20px; }
.text-3xl  { font-size: 24px; }
.text-4xl  { font-size: 36px; }
.text-5xl  { font-size: 48px; }
.text-6xl  { font-size: 60px; }
.text-7xl  { font-size: 72px; }

.font-normal { -unity-font-style: normal; }
.font-bold   { -unity-font-style: bold; }
.font-italic { -unity-font-style: italic; }

.text-white  { color: white; }
.text-muted  { opacity: 0.6; }

.text-left   { -unity-text-align: middle-left;   }
.text-center { -unity-text-align: middle-center; }
.text-right  { -unity-text-align: middle-right;  }

.text-wrap   { white-space: normal; }
.text-nowrap { white-space: nowrap; }

/* --- Components --- */

.panel-frame {
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    background-color: rgba(0, 0, 0, 0.1);
    padding: 8px;
}

.separator {
    height: 1.5px;
    background-color: rgba(255, 255, 255, 0.05);
}

.note-icon {
    width: 24px;
    height: 24px;
    margin: 2px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
}

/* --- Global element resets --- */

Button {
    height: var(--interactive-md);
    padding: 12px;
    margin: 0;
    cursor: link;
}

Button:focus {
    border-color: #7baefa;
}

Button.btn-sm {
    height: var(--interactive-sm);
    padding: 8px;
    margin: 0;
}

Button.btn-icon-md {
    height: var(--interactive-md);
    width: var(--interactive-md);
    padding: 12px;
    margin: 0;
}

Button.btn-icon-sm {
    height: var(--interactive-sm);
    width: var(--interactive-sm);
    padding: 8px;
    margin: 0;
}

Button.btn-danger {
    background-color: #522;
}

Button.btn-danger:hover {
    background-color: #633;
}

Button.btn-danger:active {
    background-color: #722;
}

Button.btn-danger:focus {
    border-color: #f66;
}

Button.btn-tertiary {
    background-color: transparent;
    border-color: transparent;
}

Button.btn-tertiary:hover {
    background-color: rgba(255, 255, 255, 0.1)
}

Button.btn-tertiary:active {
    background-color: rgba(255, 255, 255, 0.2)
}

Button.btn-tertiary:focus {
    border-color: #7baefa;
}

EnumField {
    cursor: link;
}

TextElement {
    cursor: text;
}

Toggle {
    -unity-text-align: middle-left;
}

.toggle-left {
    flex-direction: row-reverse;
    -unity-text-align: middle-left;
}

.toggle-left > .unity-base-field__input {
    flex-grow: 0;
}

.toggle-left > .unity-label{
    flex-grow: 1;
}

.unity-base-field {
    margin: 0;
}

.unity-base-field__input {
    margin: 0;
    padding: 4px;
}

TextField,
TextInput {
    height: 28px;
    -unity-text-align: middle-left;
}

TextField > Label {
    flex-grow: 0;
    min-width: initial;
}

HelpBox {
    border-color: rgba(0, 0, 0, .3);
    background-color: rgba(255, 255, 255, .05);
    margin: 0;
    padding: 8px;
}

HelpBox > .unity-help-box__icon {
    max-height: 28px;
    max-width: 28px;
    min-height: 28px;
    min-width: 28px;
    margin-right: 4px;
}

HelpBox > .unity-help-box__label {
    font-size: 12px;
}

