/* ===== Atelier UI library by Kavaeric ===== */

:root {
    --interactive-sm: 28px;
    --interactive-md: 32px;
    -unity-font-definition: url("project://database/Assets/Modules/Atelier/Resources/Fonts/Inter/Inter_18pt-Regular%20SDF.asset?fileID=11400000&guid=6109aee244950ef498f9cf1c8c346e09&type=2#Inter_18pt-Regular SDF");
}

/* --- Font families --- */

.font-family-mono {
    -unity-font-definition: url("project://database/Assets/Modules/Atelier/Resources/Fonts/Iosevka/Iosevka-Regular%20SDF.asset?fileID=11400000&guid=6478dcb143291f74dbe283fc2634b071&type=2#Iosevka-Regular SDF");
    -unity-font-style: normal;
}

/* --- Layout --- */

.row { flex-direction: row; }
.col { flex-direction: column; }

.wrap     { flex-wrap: wrap; }
.grow     { flex-grow: 1; }
.grow-0   { flex-grow: 0; }
.shrink   { flex-shrink: 1; }
.shrink-0 { flex-shrink: 0; }
.basis-0  { flex-basis: 0; }

.items-start   { align-items: flex-start; }
.items-center  { align-items: center; }
.items-end     { align-items: flex-end; }
.items-stretch { align-items: stretch; }

.justify-start  { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end    { justify-content: flex-end; }

/* --- Sizing (1 unit = 4px, matching Tailwind scale) --- */

