.section-label {
    -unity-font-style: bold;
    margin-top: 12px;
    margin-bottom: 8px;
}

.help-box {
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    background-color: rgba(255, 255, 255, 0.05);
    padding: 12px;
    margin: 8px 0;
}

.help-box-label {
    color: rgba(255, 255, 255, 0.8);
    font-size: 11px;
    white-space: normal;
}
